        self.IP = self.get_parameter('robot_ip').get_parameter_value().string_value
        # self.IP = str(os.getenv("IP_address"))
        self.get_logger().info(self.IP)                                                  
        # self.srv = self.create_service(AO,  self.get_name() + '/AO', self.AO)
