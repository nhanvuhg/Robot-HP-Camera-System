    # ─── New firmware: Motion commands on port 29999 ───
    # These methods use the new syntax: pose={x,y,z,rx,ry,rz} or joint={j1,...,j6}

    def MovJ(self, x, y, z, rx, ry, rz, *dynParams):
        """
        Joint motion (new firmware syntax via port 29999)
        Uses pose={x,y,z,rx,ry,rz} format
        """
        string = "MovJ(pose={{{:f},{:f},{:f},{:f},{:f},{:f}}}".format(
            x, y, z, rx, ry, rz)
        for params in dynParams:
            if isinstance(params, (list, tuple)):
                for p in params:
                    string = string + "," + str(p)
            else:
                string = string + "," + str(params)
        string = string + ")"
        return self.sendRecvMsg(string)

    def MovL(self, x, y, z, rx, ry, rz, *dynParams):
        """
        Linear motion (new firmware syntax via port 29999)
        Uses pose={x,y,z,rx,ry,rz} format
        """
        string = "MovL(pose={{{:f},{:f},{:f},{:f},{:f},{:f}}}".format(
            x, y, z, rx, ry, rz)
        for params in dynParams:
            if isinstance(params, (list, tuple)):
                for p in params:
                    string = string + "," + str(p)
            else:
                string = string + "," + str(params)
        string = string + ")"
        return self.sendRecvMsg(string)

