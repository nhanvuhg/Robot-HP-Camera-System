    def connect(self):
        # ─── Step 1: Connect Dashboard (port 29999) ───
        try:
            self.get_logger().info("connection:29999")
            self.dashboard = DobotApiDashboard(self.IP, 29999)
            self.get_logger().info("✅ Dashboard connected (29999)")
        except Exception as e:
            self.get_logger().error(f"❌ Dashboard connection failed (29999): {e}")
            return

        # ─── Step 2: Enable Robot via Dashboard ───
        try:
            result = self.dashboard.EnableRobot([0.0])
            self.get_logger().info(f"EnableRobot result: {result}")
            time.sleep(2)
        except Exception as e:
            self.get_logger().warn(f"⚠️ EnableRobot failed: {e}")

        # ─── Step 3: Connect Motion port (30003) with retries ───
        max_retries = 10
        retry_delay = 3  # seconds
        self.move = None

        for attempt in range(1, max_retries + 1):
            try:
                self.get_logger().info(f"connection:30003 (attempt {attempt}/{max_retries})")
                self.move = DobotApiMove(self.IP, 30003)
                self.get_logger().info(f"✅ Motion port connected (30003) on attempt {attempt}")
                break
            except Exception as e:
                self.get_logger().warn(
                    f"⚠️ Motion port 30003 refused (attempt {attempt}/{max_retries}): {e}")
                if attempt < max_retries:
                    self.get_logger().info(f"⏳ Retrying in {retry_delay}s...")
                    time.sleep(retry_delay)
                else:
                    self.get_logger().warn(
                        f"⚠️ Motion port 30003 failed after {max_retries} attempts. "
                        "Falling back to dashboard port (29999) for motion commands.")
                    # Fallback: use dashboard connection for motion too
                    self.move = DobotApiMove(self.IP, 29999)
                    self.get_logger().info("✅ Motion commands routed via dashboard port (29999)")

    def EnableRobot(self, request, response):                                           
        return_t = self.dashboard.EnableRobot([request.load])
        return_tt = return_t[:return_t.find("{")-1]
        response.res = int(return_tt)                                           
        self.get_logger().info(return_t)                                        
        return response 
    
