    def  GetPose(self,User=0,Tool=0):
        # New firmware: GetPose() without params
        string = "GetPose()"
        result = self.sendRecvMsg(string)
        # If new firmware returns valid data, use it; otherwise try old syntax
        if result and ",{}" not in result and "-50001" not in result:
            return result
        # Fallback: old firmware with User/Tool params
        string = "GetPose(User={:d},Tool={:d})".format(User,Tool)
        return self.sendRecvMsg(string)
    
