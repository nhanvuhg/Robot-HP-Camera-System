        # self.srv = self.create_service(Wait, self.get_name() + '/',self.Wait)
        self.connect() 
    def connect(self):
        # ─── Step 1: Connect to port 29999 (unified dashboard + motion) ───
        try:
            self.get_logger().info("connection:29999")
            self.dashboard = DobotApiDashboard(self.IP, 29999)
            self.get_logger().info("✅ Dashboard connected (29999)")
        except Exception as e:
            self.get_logger().error(f"❌ Dashboard connection failed (29999): {e}")
            return

        # ─── Step 2: Stop → ClearError → EnableRobot ───
        # Stop() clears any running/paused script on the controller
        # Without this, motion commands get queued but won't execute
        try:
            result = self.dashboard.sendRecvMsg("Stop()")
            self.get_logger().info(f"Stop result: {result}")
            time.sleep(1)
        except Exception as e:
            self.get_logger().warn(f"⚠️ Stop failed: {e}")

        try:
            result = self.dashboard.ClearError()
            self.get_logger().info(f"ClearError result: {result}")
        except Exception as e:
            self.get_logger().warn(f"⚠️ ClearError failed: {e}")

        try:
            result = self.dashboard.EnableRobot()
            self.get_logger().info(f"EnableRobot result: {result}")
            time.sleep(2)
        except Exception as e:
            self.get_logger().warn(f"⚠️ EnableRobot failed: {e}")

        # Verify robot is in IDLE mode (5)
        try:
            result = self.dashboard.RobotMode()
            self.get_logger().info(f"RobotMode: {result}")
        except Exception as e:
            self.get_logger().warn(f"⚠️ RobotMode check failed: {e}")

        # ─── Step 3: Motion uses same port 29999 (new firmware) ───
        # DobotApiDashboard now includes all motion methods (MovJ, MovL, etc.)
        # so we simply alias self.move to self.dashboard (shared socket)
        self.move = self.dashboard
        self.get_logger().info("✅ Motion commands routed via dashboard port (29999) — new firmware")

    def _parse_error_code(self, return_t):
        """Safely parse error code from robot response.
        Expected format: 'ErrorID,{...},CommandName();'
        Returns error code as int, or -99999 if parsing fails.
        """
        try:
            idx = return_t.find("{")
            if idx > 0:
                return int(return_t[:idx-1].strip())
            else:
                # Non-standard response (e.g. 'Control Mode Is Not Tcp')
                self.get_logger().error(f"⚠️ Non-standard response: {return_t}")
                return -99999
        except (ValueError, IndexError) as e:
            self.get_logger().error(f"⚠️ Failed to parse response '{return_t}': {e}")
            return -99999

    def EnableRobot(self, request, response):                                           
        return_t = self.dashboard.EnableRobot([request.load])
        response.res = self._parse_error_code(return_t)                                           
        self.get_logger().info(return_t)                                        
        return response 
    
    def ClearError(self, request, response):                                          
        return_t = self.dashboard.ClearError()
        response.res = self._parse_error_code(return_t)                                           
        self.get_logger().info(return_t)                                        
        return response 
    
    def ResetRobot(self, request, response):                                          
        return_t = self.dashboard.ResetRobot()
        response.res = self._parse_error_code(return_t)                                           
        self.get_logger().info(return_t)                                        
        return response 
    
